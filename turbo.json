{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "DORIS_HOST",
    "DORIS_PORT",
    "DORIS_USER",
    "DORIS_PASSWORD",
    "DORIS_DB",
    "DORIS_STREAM_LOAD_HOST",
    "DORIS_STREAM_LOAD_PORT",
    "DORIS_STREAM_LOAD_TIMEOUT_MS",
    "TELEMETRY_STREAM_LOAD",
    "REDIS_URL",
    "BLOB_ENDPOINT",
    "BLOB_REGION",
    "BLOB_BUCKET",
    "BLOB_ACCESS_KEY_ID",
    "BLOB_SECRET_ACCESS_KEY",
    "MEMOTURN_BASE_URL",
    "MEMOTURN_PUBLIC_KEY",
    "MEMOTURN_SECRET_KEY",
    "PG_PORT",
    "REDIS_PORT",
    "CONSOLE_URL",
    "MEMOTURN_EMAIL",
    "MEMOTURN_PASSWORD",
    "RATE_LIMIT_PER_MINUTE",
    "INGEST_EVENTS_PER_MINUTE",
    "WORKER_CONCURRENCY",
    "WORKER_PORT",
    "ENCRYPTION_KEY",
    "ALLOW_PRIVATE_WEBHOOK_TARGETS",
    "ALLOW_SEED",
    "SEED_ADMIN_EMAIL",
    "SEED_ADMIN_PASSWORD",
    "CF_ENV",
    "VITE_PUBLIC_DOCS_URL",
    "MEMOTURN_DOCS_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:status": {
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "deploy:staging": {
      "dependsOn": ["build"],
      "cache": false
    },
    "generate": {
      "cache": false
    }
  }
}
