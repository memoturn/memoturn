{
  "name": "@memoturn/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./clickhouse": "./src/clickhouse.ts",
    "./blob": "./src/blob.ts",
    "./queue": "./src/queue.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "clickhouse:migrate": "bun --env-file=../../.env src/migrate-clickhouse.ts",
    "studio": "prisma studio",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "echo 'no tests'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@clickhouse/client": "^1.10.0",
    "@memoturn/core": "workspace:*",
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
