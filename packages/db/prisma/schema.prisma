// memoturn relational metadata (OLTP). High-volume telemetry lives in ClickHouse.
// Phase 1 ships tenancy + auth + API keys + the prompt/dataset/evaluator skeletons
// that later phases fill in.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Tenancy (Better Auth organization plugin) ───────────────────────────────────
// Organization is the tenant root; Member/Invitation are managed by the org plugin.
// Projects hang off an organization. Member.role is a lowercase string
// (owner/admin/member/viewer) mapped to our WorkspaceRole in @memoturn/server.
model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  logo        String?
  metadata    String?
  createdAt   DateTime     @default(now())
  projects    Project[]
  members     Member[]
  invitations Invitation[]

  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  teamId         String?
  inviterId      String
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@map("invitation")
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  apiKeys     ApiKey[]
  prompts     Prompt[]
  datasets    Dataset[]
  evaluators  Evaluator[]
  scoreConfigs ScoreConfig[]
  providers   ProviderConnection[]
  auditLogs   AuditLog[]
  reviewQueues ReviewQueue[]
  retention   RetentionPolicy?
  webhooks    Webhook[]
  widgets     Widget[]
  comments    Comment[]
  savedViews  SavedView[]
  modelPrices ModelPrice[]
  scheduledExport ScheduledExport?
  automations Automation[]

  @@unique([organizationId, slug])
}

// ── Auth (Better Auth managed: User / Session / Account / Verification) ───────────
model User {
  id            String       @id
  name          String
  email         String       @unique
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions          Session[]
  accounts          Account[]
  members           Member[]
  invitations       Invitation[]
  oauthApplications OauthApplication[]
  oauthAccessTokens OauthAccessToken[]
  oauthConsents     OauthConsent[]

  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String   @unique
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ── OIDC provider (Better Auth oidc-provider plugin) ─────────────────────────────
// memoturn acts as an OAuth2/OIDC provider: registered apps + issued tokens + consent.
model OauthApplication {
  id           String             @id @default(cuid())
  name         String
  icon         String?
  metadata     String?
  clientId     String             @unique
  clientSecret String?
  redirectUrls String
  type         String
  disabled     Boolean            @default(false)
  userId       String?
  user         User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  accessTokens OauthAccessToken[]
  consents     OauthConsent[]

  @@index([userId])
  @@map("oauthApplication")
}

model OauthAccessToken {
  id                    String           @id @default(cuid())
  accessToken           String           @unique
  refreshToken          String?          @unique
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime?
  clientId              String
  application           OauthApplication @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  userId                String?
  user                  User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes                String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauthAccessToken")
}

model OauthConsent {
  id           String           @id @default(cuid())
  clientId     String
  application  OauthApplication @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes       String
  consentGiven Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauthConsent")
}

// API keys are project scoped. The secret is hashed; the public key and a
// short hint are stored for display + lookup. Validation result is cached in Redis.
model ApiKey {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publicKey     String   @unique
  secretHash    String
  secretHint    String // last 4 chars, for display
  name          String?
  createdAt     DateTime @default(now())
  lastUsedAt    DateTime?

  @@index([projectId])
}

// ── Prompt management (Phase 4) ─────────────────────────────────────────────────
enum PromptType {
  TEXT
  CHAT
}

model Prompt {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  folder    String          @default("")
  createdAt DateTime        @default(now())
  versions  PromptVersion[]
  channels  PromptChannel[]

  @@unique([projectId, name])
}

model PromptVersion {
  id        String     @id @default(cuid())
  promptId  String
  prompt    Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  version   Int
  type      PromptType @default(TEXT)
  content   Json // string for TEXT, message array for CHAT
  config    Json       @default("{}") // model + params
  createdAt DateTime   @default(now())

  @@unique([promptId, version])
}

// Deployment pointers ("channels") — e.g. production / latest / custom labels.
model PromptChannel {
  id        String   @id @default(cuid())
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  label     String
  version   Int
  updatedAt DateTime @updatedAt

  @@unique([promptId, label])
}

// ── Datasets & evaluation (Phase 5) ─────────────────────────────────────────────
model Dataset {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String        @default("")
  createdAt   DateTime      @default(now())
  items       DatasetItem[]
  runs        DatasetRun[]

  @@unique([projectId, name])
}

model DatasetItem {
  id             String           @id @default(cuid())
  datasetId      String
  dataset        Dataset          @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  input          Json
  expectedOutput Json?
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now())
  runItems       DatasetRunItem[]

  @@index([datasetId])
}

// An experiment run over a dataset (e.g. "gpt-4o-baseline"). Each run item links a
// dataset item to the trace produced by running the task on it; scores against that
// trace (in ClickHouse) are the experiment's results.
model DatasetRun {
  id        String           @id @default(cuid())
  datasetId String
  dataset   Dataset          @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  name      String
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())
  items     DatasetRunItem[]

  @@unique([datasetId, name])
}

model DatasetRunItem {
  id            String      @id @default(cuid())
  runId         String
  run           DatasetRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  datasetItemId String
  datasetItem   DatasetItem @relation(fields: [datasetItemId], references: [id], onDelete: Cascade)
  traceId       String
  createdAt     DateTime    @default(now())

  @@unique([runId, datasetItemId])
  @@index([runId])
}

// Evaluators: managed LLM-as-judge templates or custom. Bindings (online sampling /
// dataset targets) come in Phase 5.
model Evaluator {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  prompt       String // judge prompt / instructions
  provider     String   @default("mock")
  model        String
  outputSchema Json     @default("{}")
  // Online evaluation: when enabled, the worker runs this evaluator on a sampled
  // fraction of incoming completed traces (optionally filtered by trace name).
  online       Boolean  @default(false)
  samplingRate Float    @default(1.0)
  filterName   String   @default("")
  createdAt    DateTime @default(now())

  @@unique([projectId, name])
}

model ScoreConfig {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  dataType  String   @default("NUMERIC") // NUMERIC | CATEGORICAL | BOOLEAN
  config    Json     @default("{}") // ranges / categories
  createdAt DateTime @default(now())

  @@unique([projectId, name])
}

// Encrypted provider credentials for playground + LLM-as-judge.
model ProviderConnection {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider      String // openai | anthropic | ...
  encryptedKey  String
  createdAt     DateTime @default(now())

  @@unique([projectId, provider])
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor     String
  action    String
  target    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

// Human annotation: a queue of traces to be manually scored. Submitting a review
// writes an ANNOTATION score (to ClickHouse) and marks the item done.
model ReviewQueue {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String       @default("")
  scoreName   String // the score this queue assigns, e.g. "human-rating"
  dataType    String       @default("NUMERIC") // NUMERIC | CATEGORICAL | BOOLEAN
  createdAt   DateTime     @default(now())
  items       ReviewItem[]

  @@unique([projectId, name])
}

// Data retention: traces/observations/scores older than `days` are deleted by the
// worker's daily retention job (and on-demand via the API). 0 = keep forever.
model RetentionPolicy {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  days      Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Outbound webhook / automation: POSTs to `url` when `event` fires. For score.created,
// an optional `threshold` only fires when score.value < threshold (low-score alerts).
model Webhook {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  event     String   @default("score.created")
  threshold Float?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([projectId, event])
}

// A trigger->action automation: when `trigger` fires (score.created / trace.created /
// eval.completed), run `action` (webhook POST or Slack message) against `target`.
// Optional threshold (score triggers) + filter (substring on the entity name).
model Automation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  trigger   String   @default("score.created") // score.created | trace.created | eval.completed
  action    String   @default("webhook") // webhook | slack
  target    String // URL (HTTP endpoint or Slack incoming webhook)
  threshold Float?
  filter    String   @default("") // substring match on the entity name ("" = any)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([projectId, trigger])
}

// A comment on a trace / observation / session / prompt.
model Comment {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  objectType String // TRACE | OBSERVATION | SESSION | PROMPT
  objectId   String
  author     String
  content    String
  createdAt  DateTime @default(now())

  @@index([projectId, objectType, objectId])
}

// A user-defined dashboard widget: a metric query over the daily rollup.
model Widget {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  metric    String   @default("cost") // cost | tokens | generations | latency_p95
  breakdown String   @default("by_day") // by_day | by_model
  days      Int      @default(30)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([projectId])
}

model ReviewItem {
  id          String      @id @default(cuid())
  queueId     String
  queue       ReviewQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  traceId     String
  status      String      @default("PENDING") // PENDING | DONE | SKIPPED
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  @@unique([queueId, traceId])
  @@index([queueId, status])
}

// A named, saved set of table filters (e.g. for the traces explorer) a user can re-apply.
model SavedView {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  table     String   @default("traces") // which table the view applies to
  name      String
  filters   Json     @default("{}") // serialized filter object
  createdAt DateTime @default(now())

  @@index([projectId, table])
}

// Recurring export of a project's traces (NDJSON) to blob storage. A daily worker
// cron sweeps every enabled config; status fields record the last run for the UI.
model ScheduledExport {
  id          String    @id @default(cuid())
  projectId   String    @unique
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabled     Boolean   @default(false)
  environment String    @default("") // optional environment filter ("" = all)
  limit       Int       @default(1000)
  lastRunAt   DateTime?
  lastKey     String    @default("")
  lastCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Per-project model price override. `pattern` is a case-insensitive regex matched
// against the model name; it takes precedence over the built-in registry in @memoturn/core.
model ModelPrice {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pattern       String // model-name regex source, e.g. ^my-model
  provider      String   @default("")
  inputPerMTok  Float
  outputPerMTok Float
  createdAt     DateTime @default(now())

  @@unique([projectId, pattern])
}
