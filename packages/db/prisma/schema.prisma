// memoturn relational metadata (OLTP). High-volume telemetry lives in Apache Doris.
// Phase 1 ships tenancy + auth + API keys + the prompt/dataset/evaluator skeletons
// that later phases fill in.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Tenancy (Better Auth organization plugin) ───────────────────────────────────
// Organization is the tenant root; Member/Invitation are managed by the org plugin.
// Projects hang off an organization. Member.role is a lowercase string
// (owner/admin/member/viewer) mapped to our WorkspaceRole in @memoturn/server.
model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  logo        String?
  metadata    String?
  createdAt   DateTime     @default(now())
  projects    Project[]
  members     Member[]
  invitations Invitation[]

  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId]) // membership-by-user: session-create default org, project resolution
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  teamId         String?
  inviterId      String
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@index([organizationId]) // org invitations list
  @@index([email]) // pending-invites lookup on signup/accept
  @@map("invitation")
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  apiKeys         ApiKey[]
  prompts         Prompt[]
  datasets        Dataset[]
  evaluators      Evaluator[]
  scoreConfigs    ScoreConfig[]
  providers       ProviderConnection[]
  auditLogs       AuditLog[]
  reviewQueues    ReviewQueue[]
  retention       RetentionPolicy?
  samplingPolicy  SamplingPolicy?
  usageDaily      UsageDaily[]
  webhooks        Webhook[]
  webhookDeliveries WebhookDelivery[]
  widgets         Widget[]
  dashboards      Dashboard[]
  comments        Comment[]
  savedViews      SavedView[]
  modelPrices     ModelPrice[]
  scheduledExport ScheduledExport?
  automations     Automation[]
  analyticsSink   AnalyticsSink?
  maskingPolicy   MaskingPolicy?
  guardrailPolicy GuardrailPolicy?
  experiments     Experiment[]
  alertRules      AlertRule[]
  budget          CostBudget?
  projectMembers  ProjectMember[]
  traceStates     TraceState[]
  observationStates ObservationState[]
  scoreStates     ScoreState[]

  @@unique([organizationId, slug])
}

// Project-level RBAC: a per-project role assignment that OVERRIDES the user's org-level
// Member.role for this one project (elevate or restrict). Absence = inherit the org role.
// The user must still belong to the project's organization.
model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@map("projectMember")
}

// ── Auth (Better Auth managed: User / Session / Account / Verification) ───────────
model User {
  id                String             @id
  name              String
  email             String             @unique
  emailVerified     Boolean            @default(false)
  image             String?
  twoFactorEnabled  Boolean?           @default(false)
  role              String?
  banned            Boolean?           @default(false)
  banReason         String?
  banExpires        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  accounts          Account[]
  members           Member[]
  invitations       Invitation[]
  ssoProviders      SsoProvider[]
  oauthClients      OauthClient[]
  oauthRefreshTokens OauthRefreshToken[]
  oauthAccessTokens OauthAccessToken[]
  oauthConsents     OauthConsent[]
  twoFactors        TwoFactor[]
  passkeys          Passkey[]
  projectMembers    ProjectMember[]

  @@map("user")
}

// Better Auth two-factor plugin: TOTP secret + backup codes (both stored encrypted by the
// plugin). One row per user once 2FA is enabled; user.twoFactorEnabled gates the challenge.
model TwoFactor {
  id          String  @id
  secret      String
  backupCodes String
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

// Better Auth passkey plugin (WebAuthn/FIDO2). One row per registered credential.
model Passkey {
  id           String    @id
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime? @default(now())

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String   @unique
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  impersonatedBy       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  oauthRefreshTokens   OauthRefreshToken[]
  oauthAccessTokens    OauthAccessToken[]

  @@index([userId]) // list/revoke a user's sessions (admin ban, revoke-others on reset)
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId]) // credential/provider lookup on every password or social sign-in
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier]) // magic-link/OTP/reset token verification path
  @@map("verification")
}

// ── SSO (Better Auth @better-auth/sso plugin) ────────────────────────────────────
// An external identity provider (OIDC or SAML) a customer's users authenticate with.
// Mapped to an organization + email domain so domain users land in the right tenant.
model SsoProvider {
  id             String  @id @default(cuid())
  issuer         String
  oidcConfig     String?
  samlConfig     String?
  userId         String?
  user           User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId     String  @unique
  organizationId String?
  domain         String

  @@index([domain]) // IdP resolution by email domain on every SSO sign-in
  @@map("ssoProvider")
}

// ── OAuth 2.1 provider (Better Auth @better-auth/oauth-provider plugin) ──────────
// Registered OAuth clients (dynamic client registration for MCP IDEs), rotating refresh
// tokens, opaque access tokens (unused while JWT access tokens are enabled — the plugin
// requires the table regardless), and per-user scope consent. Powers the remote MCP
// endpoint's OAuth flow (memoturn cloud). Replaces the deprecated mcp() plugin tables.
model OauthClient {
  id                      String              @id @default(cuid())
  clientId                String              @unique
  clientSecret            String? // hashed at rest (storeClientSecret: "hashed")
  disabled                Boolean?            @default(false)
  skipConsent             Boolean?
  enableEndSession        Boolean?
  subjectType             String?
  scopes                  String[]
  userId                  String?
  user                    User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime?           @default(now())
  updatedAt               DateTime?           @updatedAt
  name                    String?
  uri                     String?
  icon                    String?
  contacts                String[]
  tos                     String?
  policy                  String?
  softwareId              String?
  softwareVersion         String?
  softwareStatement       String?
  redirectUris            String[]
  postLogoutRedirectUris  String[]
  tokenEndpointAuthMethod String?
  grantTypes              String[]
  responseTypes           String[]
  public                  Boolean?
  type                    String?
  requirePKCE             Boolean?
  referenceId             String?
  metadata                Json?
  refreshTokens           OauthRefreshToken[]
  accessTokens            OauthAccessToken[]
  consents                OauthConsent[]

  @@index([userId])
  @@map("oauthClient")
}

model OauthRefreshToken {
  id           String             @id @default(cuid())
  token        String             @unique
  clientId     String
  client       OauthClient        @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  sessionId    String?
  session      Session?           @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId  String?
  expiresAt    DateTime?
  createdAt    DateTime?          @default(now())
  revoked      DateTime?
  authTime     DateTime?
  scopes       String[]
  accessTokens OauthAccessToken[]

  @@index([clientId])
  @@index([sessionId])
  @@index([userId])
  @@map("oauthRefreshToken")
}

model OauthAccessToken {
  id           String             @id @default(cuid())
  token        String?            @unique
  clientId     String
  client       OauthClient        @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  sessionId    String?
  session      Session?           @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId       String?
  user         User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId  String?
  refreshId    String?
  refreshToken OauthRefreshToken? @relation(fields: [refreshId], references: [id], onDelete: Cascade)
  expiresAt    DateTime?
  createdAt    DateTime?          @default(now())
  scopes       String[]

  @@index([clientId])
  @@index([sessionId])
  @@index([userId])
  @@index([refreshId])
  @@map("oauthAccessToken")
}

model OauthConsent {
  id          String      @id @default(cuid())
  clientId    String
  client      OauthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId String?
  scopes      String[]
  createdAt   DateTime?   @default(now())
  updatedAt   DateTime?   @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauthConsent")
}

// Better Auth jwt plugin: signing keypairs for JWT access tokens (private key encrypted
// at rest by the plugin). Served at /auth/jwks for resource-side verification.
model Jwks {
  id         String    @id @default(cuid())
  publicKey  String
  privateKey String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@map("jwks")
}

// API keys are project scoped. The secret is hashed; the public key and a
// short hint are stored for display + lookup. Validation result is cached in Redis.
model ApiKey {
  id                 String    @id @default(cuid())
  projectId          String
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publicKey          String    @unique
  secretHash         String
  secretHint         String // last 4 chars, for display
  name               String?
  expiresAt          DateTime? // null = never expires
  rateLimitPerMinute Int? // per-key override; null = project/global default
  scopes             String[]  @default(["read", "write", "ingest"]) // coarse access scopes
  createdAt          DateTime  @default(now())
  lastUsedAt         DateTime?

  @@index([projectId])
}

// ── Prompt management (Phase 4) ─────────────────────────────────────────────────
enum PromptType {
  TEXT
  CHAT
}

model Prompt {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  folder    String          @default("")
  createdAt DateTime        @default(now())
  versions  PromptVersion[]
  channels  PromptChannel[]

  @@unique([projectId, name])
}

model PromptVersion {
  id        String     @id @default(cuid())
  promptId  String
  prompt    Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  version   Int
  type      PromptType @default(TEXT)
  content   Json // string for TEXT, message array for CHAT
  config    Json       @default("{}") // model + params
  createdAt DateTime   @default(now())

  @@unique([promptId, version])
}

// Deployment pointers ("channels") — e.g. production / latest / custom labels.
model PromptChannel {
  id        String   @id @default(cuid())
  promptId  String
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  label     String
  version   Int
  // A/B experiment: version stays the control/fallback arm. splitVersion is the
  // challenger; splitWeight (0-100) is the percent of traffic routed to it (0 = off).
  splitVersion Int?
  splitWeight  Int    @default(0)
  status       String @default("stable") // "stable" | "experiment"
  updatedAt DateTime @updatedAt

  @@unique([promptId, label])
}

// ── Datasets & evaluation (Phase 5) ─────────────────────────────────────────────
model Dataset {
  id             String           @id @default(cuid())
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  description    String           @default("")
  // Highest version number cut for this dataset (0 = no version cut yet). Cutting a
  // version freezes the current DatasetItem working set into a DatasetVersion snapshot.
  currentVersion Int              @default(0)
  createdAt      DateTime         @default(now())
  items          DatasetItem[]
  runs           DatasetRun[]
  versions       DatasetVersion[]
  experiments    Experiment[]

  @@unique([projectId, name])
}

model DatasetItem {
  id             String           @id @default(cuid())
  datasetId      String
  dataset        Dataset          @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  input          Json
  expectedOutput Json?
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now())
  runItems       DatasetRunItem[]

  @@index([datasetId])
}

// An experiment run over a dataset (e.g. "gpt-4o-baseline"). Each run item links a
// dataset item to the trace produced by running the task on it; scores against that
// trace (in Doris) are the experiment's results.
model DatasetRun {
  id        String           @id @default(cuid())
  datasetId String
  dataset   Dataset          @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  name      String
  metadata  Json             @default("{}")
  // The dataset version this run executed against (nullable for runs recorded before
  // versioning; SetNull so deleting a version doesn't cascade-delete run history).
  versionId String?
  version   DatasetVersion?  @relation(fields: [versionId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())
  items     DatasetRunItem[]

  @@unique([datasetId, name])
}

// Immutable snapshot of a dataset's DatasetItem working set at cut time. Runs pin a
// versionId so an experiment is reproducible even if the working set is later edited.
model DatasetVersion {
  id          String               @id @default(cuid())
  datasetId   String
  dataset     Dataset              @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  version     Int // monotonic per dataset (1,2,3,…)
  label       String               @default("") // optional human label, e.g. "golden-v2"
  description String               @default("")
  itemCount   Int                  @default(0)
  createdAt   DateTime             @default(now())
  items       DatasetVersionItem[]
  runs        DatasetRun[]

  @@unique([datasetId, version])
  @@index([datasetId])
}

// Frozen copy of one item's content as of a version (copy-on-write at snapshot time).
model DatasetVersionItem {
  id             String         @id @default(cuid())
  versionId      String
  version        DatasetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  datasetItemId  String // provenance pointer to the live item (may be edited/deleted later)
  input          Json
  expectedOutput Json?
  metadata       Json           @default("{}")

  @@index([versionId])
}

model DatasetRunItem {
  id            String      @id @default(cuid())
  runId         String
  run           DatasetRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  datasetItemId String
  datasetItem   DatasetItem @relation(fields: [datasetItemId], references: [id], onDelete: Cascade)
  traceId       String
  createdAt     DateTime    @default(now())

  @@unique([runId, datasetItemId])
  @@index([runId])
}

// Evaluators: managed LLM-as-judge templates or custom. Bindings (online sampling /
// dataset targets) come in Phase 5.
model Evaluator {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  prompt       String // judge prompt / instructions
  provider     String   @default("mock")
  model        String
  outputSchema Json     @default("{}")
  // Online evaluation: when enabled, the worker runs this evaluator on a sampled
  // fraction of incoming completed traces (optionally filtered by trace name).
  online       Boolean  @default(false)
  samplingRate Float    @default(1.0)
  filterName   String   @default("")
  // Monotonic version, bumped whenever the judge prompt/model/provider changes. The
  // immutable history lives in EvaluatorVersion so online score drift is attributable
  // (correlate a score-trend shift to when a version was published).
  version      Int      @default(1)
  createdAt    DateTime @default(now())

  versions EvaluatorVersion[]

  @@unique([projectId, name])
}

// Immutable snapshot of an evaluator's judge config at a point in time. A new row is
// written on every create/edit that changes the prompt/model/provider.
model EvaluatorVersion {
  id           String    @id @default(cuid())
  evaluatorId  String
  evaluator    Evaluator @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
  version      Int
  prompt       String
  provider     String
  model        String
  createdAt    DateTime  @default(now())

  @@unique([evaluatorId, version])
}

enum ExperimentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// A server-executed experiment: run every dataset item through a prompt-version × model
// (+ params), auto-score each output with evaluators, and produce a DatasetRun for
// comparison. Config + lifecycle live here (OLTP); output traces + EVAL scores go to the
// telemetry store via the normal ingest path.
model Experiment {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  datasetId String
  dataset   Dataset          @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  name      String // also the DatasetRun name it produces
  status    ExperimentStatus @default(PENDING)

  // Execution config
  provider      String  @default("mock")
  model         String
  params        Json    @default("{}") // { temperature, maxTokens, ... }
  promptName    String  @default("") // "" = use item.input directly
  promptChannel String  @default("")
  promptVersion Int? // resolved version snapshot, so re-runs are reproducible
  evaluators    String[] @default([]) // Evaluator.name list to run per item

  // Progress
  totalItems     Int    @default(0)
  completedItems Int    @default(0)
  failedItems    Int    @default(0)
  error          String @default("")

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  items ExperimentItemResult[]

  @@unique([datasetId, name])
  @@index([projectId, status])
}

// Per-item execution checkpoint — the idempotency/resume key. A retried job skips items
// already DONE so a trace is never double-written to the (append-only) telemetry store.
model ExperimentItemResult {
  id            String     @id @default(cuid())
  experimentId  String
  experiment    Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  datasetItemId String
  status        String     @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  traceId       String     @default("")
  error         String     @default("")
  attempts      Int        @default(0)
  updatedAt     DateTime   @updatedAt

  @@unique([experimentId, datasetItemId])
  @@index([experimentId, status])
}

model ScoreConfig {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  dataType  String   @default("NUMERIC") // NUMERIC | CATEGORICAL | BOOLEAN
  config    Json     @default("{}") // ranges / categories
  createdAt DateTime @default(now())

  @@unique([projectId, name])
}

// Encrypted provider credentials for playground + LLM-as-judge.
model ProviderConnection {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider     String // openai | anthropic | ...
  encryptedKey String
  createdAt    DateTime @default(now())

  @@unique([projectId, provider])
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor     String
  action    String
  target    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

// Human annotation: a queue of traces to be manually scored. Submitting a review
// writes an ANNOTATION score (to Doris) and marks the item done.
model ReviewQueue {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String       @default("")
  scoreName   String // the score this queue assigns, e.g. "human-rating"
  dataType    String       @default("NUMERIC") // NUMERIC | CATEGORICAL | BOOLEAN
  createdAt   DateTime     @default(now())
  items       ReviewItem[]

  @@unique([projectId, name])
}

// Data retention: traces/observations/scores older than `days` are deleted by the
// worker's daily retention job (and on-demand via the API). 0 = keep forever.
model RetentionPolicy {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  days      Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Per-project head-based ingest sampling: `rate` is the percent (0-100) of traces
// KEPT in the query store (100 = keep all). Mirrors RetentionPolicy's shape.
// Ingest sampling. `rate` is head sampling (percent of traces kept, stable per-id hash).
// The keep-rules add tail sampling: a trace is ALSO kept — regardless of the head dice —
// when it looks interesting (has an error span / is slow / is expensive), so a low rate
// still preserves the traces worth debugging. null keep-fields = that rule is off.
model SamplingPolicy {
  id             String   @id @default(cuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rate           Int      @default(100)
  keepOnError    Boolean  @default(false)
  keepLatencyMs  Int?
  keepMinCostUsd Float?
  updatedAt      DateTime @updatedAt
}

// Volume-based usage metering: bytes/events/traces ingested per project per UTC day.
// Measured on the raw batch at ingest time (independent of sampling — usage counts
// everything sent), the foundation for cloud billing by GB ingested. `@@unique` makes
// the worker's per-batch upsert-increment idempotent-by-key.
model UsageDaily {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date      String // 'YYYY-MM-DD' (UTC)
  bytes     BigInt  @default(0)
  events    Int     @default(0)
  traces    Int     @default(0)

  @@unique([projectId, date])
  @@index([projectId, date])
}

// Outbound webhook / automation: POSTs to `url` when `event` fires. For score.created,
// an optional `threshold` only fires when score.value < threshold (low-score alerts).
model Webhook {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url           String
  event         String    @default("score.created")
  threshold     Float?
  enabled       Boolean   @default(true)
  secret        String    @default("")
  lastStatus    Int? // HTTP status of the most recent delivery attempt (null = never fired)
  lastError     String    @default("") // error message of the last failed attempt
  lastAttemptAt DateTime? // when the most recent delivery was attempted
  failureCount  Int       @default(0) // consecutive failures since the last success
  createdAt     DateTime  @default(now())
  deliveries    WebhookDelivery[]

  @@index([projectId, event])
}

// One row per webhook delivery attempt-set (the historical log; the Webhook row keeps only
// the latest snapshot). Powers the delivery-log drill-in and debugging retries.
model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  event      String
  status     Int? // final HTTP status (null = network error / never responded)
  ok         Boolean
  error      String   @default("")
  attempts   Int      @default(1) // how many attempts were made before the final outcome
  durationMs Int? // total wall time across attempts
  createdAt  DateTime @default(now())

  @@index([webhookId, createdAt])
  @@index([projectId, createdAt])
  @@map("webhookDelivery")
}

// A trigger->action automation: when `trigger` fires (score.created / trace.created /
// eval.completed), run `action` (webhook POST or Slack message) against `target`.
// Optional threshold (score triggers) + filter (substring on the entity name).
model Automation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  trigger   String   @default("score.created") // score.created | trace.created | eval.completed
  action    String   @default("webhook") // webhook | slack
  target    String // URL (HTTP endpoint or Slack incoming webhook)
  threshold Float?
  filter    String   @default("") // substring match on the entity name ("" = any)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([projectId, trigger])
}

// A stateful alert rule: a worker cron evaluates `metric` over a trailing `window`
// (minutes) and fires when it crosses `threshold` per `comparator`. Unlike an
// event-triggered Automation, an AlertRule carries firing/resolved state (AlertState)
// so it notifies only on transitions. `channels` is a JSON array of { type, target }.
model AlertRule {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  metric     String // error_rate | latency_p95 | cost_per_day | ingest_volume | dlq_depth
  window     Int        @default(5) // trailing window in minutes
  threshold  Float
  comparator String     @default("gt") // gt | gte | lt | lte
  channels   Json       @default("[]") // [{ type: "slack" | "webhook", target: "https://…" }]
  filter     String     @default("") // reserved: substring match (unused today)
  enabled    Boolean    @default(true)
  createdAt  DateTime   @default(now())
  state      AlertState?

  @@index([projectId, enabled])
}

// The firing/resolved state of one AlertRule (1:1). The cron transitions ok→firing on
// breach and firing→resolved on recovery, notifying only on transition (dedup).
model AlertState {
  id             String    @id @default(cuid())
  ruleId         String    @unique
  rule           AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  status         String    @default("ok") // ok | firing | resolved
  lastValue      Float?
  lastFiredAt    DateTime?
  lastResolvedAt DateTime?
  updatedAt      DateTime  @updatedAt
}

// Per-project monthly USD spend budget. The cron compares month-to-date cost to
// `monthlyUsd` * each step in `thresholds` (e.g. 50/80/100%) and notifies once per step
// via `channels`; `notifiedThreshold` records the highest crossed step so it doesn't
// re-alert every tick. Soft only — no hard caps (memoturn is not a gateway).
model CostBudget {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  monthlyUsd        Float
  thresholds        Json     @default("[0.5,0.8,1.0]")
  notifiedThreshold Float    @default(0) // highest step already notified this month
  channels          Json     @default("[]")
  createdAt         DateTime @default(now())
}

// A comment on a trace / observation / session / prompt.
model Comment {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  objectType String // TRACE | OBSERVATION | SESSION | PROMPT
  objectId   String
  author     String
  content    String
  createdAt  DateTime @default(now())

  @@index([projectId, objectType, objectId])
}

// A user-defined dashboard widget: a metric query over the daily rollup.
// A named dashboard groups a project's widgets. Widgets with a null dashboardId belong to
// the implicit "Default" dashboard, so pre-existing widgets keep working after the migration.
model Dashboard {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  position  Int      @default(0)
  filters   Json     @default("[]") // dashboard-level structured filter set, applied to all widgets
  createdAt DateTime @default(now())
  widgets   Widget[]

  @@index([projectId])
}

model Widget {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dashboardId String? // null = the implicit "Default" dashboard
  dashboard   Dashboard? @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  title       String
  // Legacy single-metric model (the original dashboard tiles).
  metric      String     @default("cost") // cost | tokens | generations | latency_p95 | error_rate | score
  breakdown   String     @default("by_day") // by_day | by_model | by_user | by_session
  days        Int        @default(30)
  filters     Json       @default("{}") // { environment?, model?, tag? }
  // Generic query-engine model (widgets built in Explore): when `query` is set the widget renders
  // via runAnalyticsQuery + the chart library instead of the legacy metric/breakdown path.
  query       Json? // AnalyticsQuery
  chartType   String? // line | bar | horizontal_bar | big_number | pie | table
  // 12-column grid placement.
  gridX       Int        @default(0)
  gridY       Int        @default(0)
  gridW       Int        @default(6)
  gridH       Int        @default(4)
  position    Int        @default(0)
  createdAt   DateTime   @default(now())

  @@index([projectId])
  @@index([dashboardId])
}

model ReviewItem {
  id          String      @id @default(cuid())
  queueId     String
  queue       ReviewQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  traceId     String
  status      String      @default("PENDING") // PENDING | DONE | SKIPPED
  assigneeId  String? // user id this item is assigned to (annotation assignments)
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  @@unique([queueId, traceId])
  @@index([queueId, status])
  @@index([assigneeId])
}

// A named, saved set of table filters (e.g. for the traces explorer) a user can re-apply.
model SavedView {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  table     String   @default("traces") // which table the view applies to
  name      String
  filters   Json     @default("{}") // serialized filter object
  createdAt DateTime @default(now())

  @@index([projectId, table])
}

// PII masking policy: redact sensitive data from trace/observation input/output at
// ingest (worker), before Doris. `builtins` are named patterns (email/…),
// `customPatterns` are user-supplied regex sources.
model MaskingPolicy {
  id             String   @id @default(cuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabled        Boolean  @default(false)
  builtins       String[] @default([])
  customPatterns String[] @default([])
  redactWith     String   @default("[REDACTED]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Runtime guardrails: the request-time sibling of MaskingPolicy. An SDK-callable
// endpoint (POST /v1/guardrails/check) scans text against this policy for PII, prompt
// injection, and blocked terms, returning allow / redact / block. One row per project.
model GuardrailPolicy {
  id               String   @id @default(cuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabled          Boolean  @default(false)
  pii              Boolean  @default(true) // detect PII (uses the masking builtin patterns)
  piiAction        String   @default("redact") // "redact" | "block"
  builtins         String[] @default([])
  customPatterns   String[] @default([])
  redactWith       String   @default("[REDACTED]")
  injection        Boolean  @default(true) // detect prompt injection (always blocks on hit)
  blockedTerms     String[] @default([]) // content-policy terms (case-insensitive; block on hit)
  sqlInjection     Boolean  @default(false) // detect SQL-injection heuristics (always blocks on hit)
  requireMatch     String[] @default([]) // regexes that MUST match; block if none do
  requireValidJson Boolean  @default(false) // require the text to be valid JSON
  requiredJsonKeys String[] @default([]) // top-level keys that must be present when parsed as JSON
  evaluatorGuards  Json     @default("[]") // EvaluatorGuard[] — { name, comparator, threshold }
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("guardrailPolicy")
}

// Product-analytics sink: forward trace/score events to PostHog for funnels.
model AnalyticsSink {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabled   Boolean  @default(false)
  type      String   @default("posthog")
  host      String   @default("https://us.i.posthog.com")
  apiKey    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Recurring export of a project's traces (NDJSON) to blob storage. A daily worker
// cron sweeps every enabled config; status fields record the last run for the UI.
model ScheduledExport {
  id          String    @id @default(cuid())
  projectId   String    @unique
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabled     Boolean   @default(false)
  environment String    @default("") // optional environment filter ("" = all)
  limit       Int       @default(1000)
  lastRunAt   DateTime?
  lastKey     String    @default("")
  lastCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Per-project model price override. `pattern` is a case-insensitive regex matched
// against the model name; it takes precedence over the built-in registry in @memoturn/core.
model ModelPrice {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pattern       String // model-name regex source, e.g. ^my-model
  provider      String   @default("")
  inputPerMTok  Float
  outputPerMTok Float
  createdAt     DateTime @default(now())

  @@unique([projectId, pattern])
}

// ── Mutable entity state (ADR-0001, Phase 1) ─────────────────────────────────────
// Authoritative, field-mergeable state for mutable telemetry entities. Ingest events
// merge into these tables field-by-field (only fields an event actually carries
// overwrite — see @memoturn/server mutable-state merge), which is transactional and
// correct under concurrency in a way Doris's single row-level sequence column can't be.
// Doris is then the analytical mirror. Additive + flag-gated (MUTABLE_STATE_STORE) in
// Phase 1; every mergeable column is NULLable so "absent in the event" = "keep stored".
// `stateVersion` is a monotonic per-row version (mirror ordering, Phase 2).

model TraceState {
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  id          String
  // Mergeable fields (mirror the Doris trace row; NULL = not provided by any event yet).
  name        String?
  timestamp   DateTime?
  userId      String?
  sessionId   String?
  release     String?
  version     String?
  environment String?
  public      Boolean?
  tags        String[]  @default([])
  metadata    String?
  input       String?
  output      String?
  stateVersion BigInt   @default(0)
  updatedAt   DateTime  @updatedAt

  @@id([projectId, id])
  @@index([updatedAt]) // prune sweep (Phase 3)
}

model ObservationState {
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  id                  String
  // Raw mergeable fields only — derived latency_ms + costs are computed at mirror time (Phase 2).
  traceId             String?
  type                String?
  parentObservationId String?
  name                String?
  startTime           DateTime?
  endTime             DateTime?
  environment         String?
  level               String?
  statusMessage       String?
  model               String?
  provider            String?
  modelParameters     String?
  promptTokens        Int?
  completionTokens    Int?
  totalTokens         Int?
  cacheReadTokens     Int?
  cacheCreationTokens Int?
  promptId            String?
  promptVersion       String?
  input               String?
  output              String?
  metadata            String?
  stateVersion        BigInt    @default(0)
  updatedAt           DateTime  @updatedAt

  @@id([projectId, id])
  @@index([updatedAt])
}

model ScoreState {
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  id            String
  // All mergeable, no derived fields. NULL source/dataType coalesce to their defaults at mirror.
  traceId       String?
  observationId String?
  name          String?
  timestamp     DateTime?
  environment   String?
  source        String?
  dataType      String?
  value         Float?
  stringValue   String?
  comment       String?
  configId      String?
  stateVersion  BigInt    @default(0)
  updatedAt     DateTime  @updatedAt

  @@id([projectId, id])
  @@index([updatedAt])
}
