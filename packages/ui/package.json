    "./composite/*": "./src/composite/*.tsx",
    "./lib/utils": "./src/lib/utils.ts",
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/base.css": "./src/styles/base.css",
    "./styles": "./src/styles/index.css"
  },
  "scripts": {
