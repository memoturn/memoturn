# memoturn reverse proxy — single public entrypoint for the single-VM production stack.
# Caddy auto-provisions a TLS cert (Let's Encrypt) for MEMOTURN_DOMAIN. Requirements:
#   - DNS A/AAAA record for MEMOTURN_DOMAIN points at this VM
#   - ports 80 and 443 are reachable from the internet (ACME HTTP/TLS challenge)
#
# Routing mirrors the dev Vite proxy (apps/console/vite.config.ts): `/api/*` is forwarded to
# the API with the `/api` prefix stripped (handle_path), so /api/v1/* -> /v1/* and
# /api/auth/* -> /auth/*. Everything else serves the console SPA.

{
	email {$ACME_EMAIL}
}

{$MEMOTURN_DOMAIN} {
	handle_path /api/* {
		reverse_proxy api:3001
	}

	# OAuth discovery for remote MCP clients — served by the API at the domain root (not the
	# console), so route these two well-known paths straight to the API with the path intact.
	# (`handle` accepts a single matcher token, hence the named matcher for both paths.)
	@oauthDiscovery path /.well-known/oauth-authorization-server /.well-known/oauth-protected-resource /.well-known/openid-configuration
	handle @oauthDiscovery {
		reverse_proxy api:3001
	}

	handle {
		# Defense-in-depth CSP for the console document (where user-controlled trace/LLM
		# content renders). Tuned for the bundled Vite SPA — no external origins; images allow
		# data:/blob: for inline media, styles allow 'unsafe-inline' for Tailwind/chart styles.
		header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
		reverse_proxy console:3000
	}
}
