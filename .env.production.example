# ─── memoturn single-VM production env ─────────────────────────────────────────
# For the Docker Compose + Caddy stack (infra/docker-compose.prod.yml). Copy to `.env`,
# fill in the values below, then:
#   docker compose -f infra/docker-compose.prod.yml --env-file .env up -d --build
#
# Only the values in this file need setting — service URLs (Postgres/Doris/Redis/MinIO)
# are wired internally by the compose file. Generate every secret with: openssl rand -base64 48

# Public hostname (DNS A/AAAA must point at this VM; ports 80+443 must be open). Caddy gets a
# TLS cert for this name and derives AUTH_BASE_URL=https://DOMAIN/api and
# AUTH_TRUSTED_ORIGINS=https://DOMAIN automatically.
MEMOTURN_DOMAIN=memoturn.example.com

# Email for Let's Encrypt expiry/issuance notices.
ACME_EMAIL=ops@example.com

# ─── Secrets (REQUIRED — no safe defaults) ──────────────────────────────────────
# Datastore credentials.
POSTGRES_PASSWORD=
DORIS_PASSWORD=
# Optional Doris memory tuning for the shared single-VM stack (defaults shown).
# DORIS_FE_XMX caps the FE JVM heap; DORIS_BE_MEM_LIMIT caps BE process memory
# (absolute like 6G, or a % of system memory).
#DORIS_FE_XMX=4096m
#DORIS_BE_MEM_LIMIT=40%
BLOB_SECRET_ACCESS_KEY=

# Better Auth session signing secret (≥16 chars; must not be a known dev placeholder).
BETTER_AUTH_SECRET=

# AES-256-GCM key for encrypting stored provider API keys at rest. Independent of
# BETTER_AUTH_SECRET. WARNING: rotating this invalidates all stored provider keys.
ENCRYPTION_KEY=

# ─── Optional (sensible defaults applied by the compose file) ────────────────────
# Blob storage identity + bucket (the secret is BLOB_SECRET_ACCESS_KEY above).
# BLOB_ACCESS_KEY_ID=memoturn
# BLOB_BUCKET=memoturn

# Allow webhooks/analytics to private/loopback/http targets. 0 (public HTTPS only) is the
# correct default for an internet-facing deploy; set 1 only if you need to reach LAN hosts.
# ALLOW_PRIVATE_WEBHOOK_TARGETS=0

# Per-project ingest rate limit (requests/minute, Redis-backed; 0 disables).
# RATE_LIMIT_PER_MINUTE=0

# Per-project ingest EVENT budget (events/minute; 0 disables) — one POST can carry up to
# 1000 events, so this meters actual volume where the request limit can't.
# INGEST_EVENTS_PER_MINUTE=0

# Per-IP throttle for the remote MCP endpoint. ON by default (120/min); 0 disables.
# MCP_RATE_LIMIT_PER_MINUTE=120

# Token-gate the API /metrics endpoint (unset = 404). Scrape with Authorization: Bearer <token>.
# API_METRICS_TOKEN=

# Worker ingest concurrency per process (single worker replica; raise for more throughput).
# WORKER_CONCURRENCY=10

# `From` address for alert + auth email (transport config: see docs/configuration.md#email).
# EMAIL_FROM=memoturn <alerts@yourdomain.com>
