{
  "name": "@memoturn/sdk",
  "version": "0.1.0",
  "description": "memoturn JS/TS SDK — tracing, OpenAI wrapper, LangChain callback, prompt fetch.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openai": "./src/openai.ts",
    "./langchain": "./src/langchain.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "openai": ">=4"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
