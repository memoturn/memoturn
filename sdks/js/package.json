{
  "name": "@memoturn/sdk",
  "version": "0.2.0",
  "description": "memoturn JS/TS SDK — tracing, OpenAI wrapper, LangChain callback, prompt fetch.",
  "license": "Apache-2.0",
  "keywords": [
    "memoturn",
    "llm",
    "observability",
    "tracing",
    "openai",
    "langchain",
    "evals",
    "opentelemetry"
  ],
  "homepage": "https://github.com/memoturn/memoturn/tree/main/sdks/js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoturn/memoturn.git",
    "directory": "sdks/js"
  },
  "bugs": "https://github.com/memoturn/memoturn/issues",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openai": "./src/openai.ts",
    "./anthropic": "./src/anthropic.ts",
    "./langchain": "./src/langchain.ts",
    "./otel": "./src/otel.ts",
    "./observe": "./src/observe.ts",
    "./prompt": "./src/prompt.ts",
    "./dataset": "./src/dataset.ts",
    "./guardrails": "./src/guardrails.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./openai": {
        "types": "./dist/openai.d.ts",
        "default": "./dist/openai.js"
      },
      "./anthropic": {
        "types": "./dist/anthropic.d.ts",
        "default": "./dist/anthropic.js"
      },
      "./langchain": {
        "types": "./dist/langchain.d.ts",
        "default": "./dist/langchain.js"
      },
      "./otel": {
        "types": "./dist/otel.d.ts",
        "default": "./dist/otel.js"
      },
      "./observe": {
        "types": "./dist/observe.d.ts",
        "default": "./dist/observe.js"
      },
      "./prompt": {
        "types": "./dist/prompt.d.ts",
        "default": "./dist/prompt.js"
      },
      "./dataset": {
        "types": "./dist/dataset.d.ts",
        "default": "./dist/dataset.js"
      },
      "./guardrails": {
        "types": "./dist/guardrails.d.ts",
        "default": "./dist/guardrails.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "prepublishOnly": "bun run build",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "openai": ">=4",
    "@anthropic-ai/sdk": ">=0.30",
    "@opentelemetry/exporter-trace-otlp-http": ">=0.50.0",
    "@opentelemetry/sdk-trace-base": ">=1.20.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@opentelemetry/exporter-trace-otlp-http": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
