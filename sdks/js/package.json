      },
      "./mistral": {
        "types": "./dist/mistral.d.ts",
        "default": "./dist/mistral.js"
      },
      "./cohere": {
        "types": "./dist/cohere.d.ts",
        "default": "./dist/cohere.js"
      },
      "./mcp": {
        "types": "./dist/mcp.d.ts",
        "default": "./dist/mcp.js"
      },
      "./langchain": {
        "types": "./dist/langchain.d.ts",
        "default": "./dist/langchain.js"
      },
      "./otel": {
        "types": "./dist/otel.d.ts",
        "default": "./dist/otel.js"
      },
      "./observe": {
        "types": "./dist/observe.d.ts",
        "default": "./dist/observe.js"
      },
      "./prompt": {
        "types": "./dist/prompt.d.ts",
