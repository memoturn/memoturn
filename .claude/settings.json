{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun run lint)",
      "Bash(bun run format)",
      "Bash(bun run typecheck)",
      "Bash(bun run test)",
      "Bash(bun run docs:check)",
      "Bash(bun run rbac:check)",
      "Bash(bun --filter @memoturn/* test)",
      "Bash(bun --filter @memoturn/* typecheck)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-generated.ts\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/.claude/hooks/doc-drift-reminder.ts\""
          }
        ]
      }
    ]
  }
}
