# Memoturn environment template. Copy to .env (gitignored) and uncomment what
# you need — every value shown is the default. memoturnd is configured
# entirely via MEMOTURN_* env vars; full reference:
# https://docs.memoturn.ai/configuration

# ── Core node ────────────────────────────────────────────────────────────
# MEMOTURN_LISTEN=127.0.0.1:8080
# MEMOTURN_DATA_DIR=./data
# MEMOTURN_NODE_ID=                 # default: derived per node
# MEMOTURN_ADVERTISE=               # default: http://$MEMOTURN_LISTEN
# MEMOTURN_HOT_CAP=50000            # hot-tier handle cap
# MEMOTURN_SINGLE_NODE=             # =1 to allow in-process leases despite
#                                   # auth-on / non-loopback advertise

# ── Object store (source of truth; local disk is cache) ─────────────────
# MEMOTURN_OBJECT_STORE=            # s3://bucket — default: local FS under DATA_DIR
# For s3:// against MinIO or any non-AWS endpoint:
# AWS_ENDPOINT=http://127.0.0.1:9000
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ALLOW_HTTP=true               # MinIO / in-cluster endpoints

# ── Cluster (multi-node needs real leases) ───────────────────────────────
# MEMOTURN_ETCD=                    # e.g. http://etcd:2379 — required multi-node

# ── Auth (fail-closed: AUTH=on requires a platform key + key source) ─────
# MEMOTURN_AUTH=off
# MEMOTURN_PLATFORM_KEY=
# MEMOTURN_AUTH_KEY=                # base64 Ed25519 signing key from a secret
# MEMOTURN_PERSIST_AUTH_KEY=        # =1 to persist a generated key to object storage
# MEMOTURN_CLUSTER_KEY=             # node-internal; must differ from the platform key

# ── Request surface & durability ──────────────────────────────────────────
# MEMOTURN_REQUEST_TIMEOUT=30       # seconds
# MEMOTURN_MAX_BODY_BYTES=33554432  # 32 MiB
# MEMOTURN_MAX_CONCURRENCY=1024
# MEMOTURN_CONTROL_RATE=10          # control-endpoint req/s
# MEMOTURN_WRITE_QUEUE_DEPTH=256    # per-DB; past it writes shed with 429
# MEMOTURN_DURABILITY=              # durable = ship+CAS before acking txid

# ── PITR & GC ─────────────────────────────────────────────────────────────
# MEMOTURN_GC_GRACE_SECS=600
# MEMOTURN_PITR_RETENTION_SECS=86400          # fine-grained window; 0 disables
# MEMOTURN_PITR_SNAPSHOT_RETENTION_SECS=2592000

# ── AI opt-ins (per-node; must stay off the write path) ───────────────────
# MEMOTURN_EXTRACT_API_KEY=         # server-side extraction
# MEMOTURN_EXTRACT_MODEL=
# MEMOTURN_ASSISTANT_API_KEY=       # recall answer synthesis (falls back to extract key)
# MEMOTURN_ASSISTANT_MODEL=
# MEMOTURN_EMBED_PROVIDER=          # voyage | openai
# MEMOTURN_EMBED_API_KEY=
# MEMOTURN_EMBED_BASE_URL=          # OpenAI-compatible / local servers
# MEMOTURN_EMBED_MODEL=

# ── Data governance (ADR-0010) ────────────────────────────────────────────
# MEMOTURN_POLICY_CACHE_SECS=30
# MEMOTURN_AUDIT_FLUSH_MS=2000
# MEMOTURN_EMBED_SELF_HOSTED_HOSTS= # allowlist for embed: self_hosted_only

# ── Client side (CLI / SDKs / MCP / examples) ─────────────────────────────
# MEMOTURN_URL=http://127.0.0.1:8080
# MEMOTURN_TOKEN=
# MEMOTURN_MCP_PORT=                # MCP server HTTP transport
# MEMOTURN_MCP_HOST=
# MEMOTURN_SOURCE=                  # default provenance source for MCP memory writes
# ANTHROPIC_API_KEY=                # enables the examples' LLM layers
