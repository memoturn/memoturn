# ─── memoturn environment ─────────────────────────────────────────────────────
# Copy to .env and adjust. The defaults match infra/docker-compose.dev.yml.

NODE_ENV=development

# Postgres (OLTP — relational metadata via Prisma)
# Host port is 5433 in docker-compose.dev.yml to avoid clashing with other local Postgres.
DATABASE_URL=postgresql://memoturn:memoturn@localhost:5433/memoturn?schema=public

# Apache Doris (OLAP — traces/observations/scores). FE MySQL-protocol port 9030,
# FE HTTP port 8030. Dev image ships with user `root` and no password.
DORIS_HOST=localhost
DORIS_PORT=9030
DORIS_HTTP_PORT=8030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DB=memoturn
# Opt-in high-throughput ingest via Doris Stream Load (HTTP) instead of multi-row INSERT.
# Off by default. When on, the worker loads over HTTP; the FE (8030) 307-redirects to a BE,
# so an in-network deploy just works. For a host-run worker, point directly at a BE:
#   TELEMETRY_STREAM_LOAD=true
#   DORIS_STREAM_LOAD_HOST=127.0.0.1
#   DORIS_STREAM_LOAD_PORT=8040   # BE webserver (dev compose now publishes it on loopback)
# TELEMETRY_STREAM_LOAD=false

# Redis / Valkey (BullMQ queues + caches) — host port 6380 to avoid clashes.
REDIS_URL=redis://localhost:6380

# Blob storage (S3-compatible; MinIO locally)
BLOB_ENDPOINT=http://localhost:9000
BLOB_REGION=us-east-1
BLOB_BUCKET=memoturn
BLOB_ACCESS_KEY_ID=memoturn
BLOB_SECRET_ACCESS_KEY=memoturn123
BLOB_FORCE_PATH_STYLE=true

# Hono API service (public /v1 + OTel receiver)
API_PORT=3001
# Enable the /metrics scrape endpoint (request counts + per-route latency percentiles).
# Unset → /metrics returns 404 (off). Set → require `Authorization: Bearer <token>`.
# API_METRICS_TOKEN=
# Per-project API rate limit (requests/minute, Redis-backed; 0 = disabled)
RATE_LIMIT_PER_MINUTE=0
# Per-project ingest EVENT rate limit (events/minute; 0 = disabled). Meters actual event
# volume — a single /v1/ingest POST can carry up to 1000 events, bypassing the request limit.
INGEST_EVENTS_PER_MINUTE=0

# Worker health + metrics endpoint (/health, /metrics)
WORKER_PORT=3002

# Console (Vite SPA) — proxies /api -> the API service in dev
CONSOLE_PORT=3000
MEMOTURN_API_URL=http://localhost:3001

# Better Auth (dashboard auth)
# In production BETTER_AUTH_SECRET, ENCRYPTION_KEY and AUTH_TRUSTED_ORIGINS are MANDATORY —
# the API/worker refuse to start without them (no insecure dev fallback). Generate with
# `openssl rand -base64 48`.
BETTER_AUTH_SECRET=dev-secret-please-change-in-prod-0123456789
AUTH_BASE_URL=http://localhost:3001
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Encryption key for provider API keys stored at rest (AES-256-GCM). Independent of
# BETTER_AUTH_SECRET. WARNING: rotating this invalidates all stored provider keys — they
# must be re-entered in Settings → Providers.
ENCRYPTION_KEY=dev-encryption-key-please-change-in-prod-0123456789

# Outbound webhook/analytics SSRF policy. By default (production) only public HTTPS URLs
# are allowed. Set to 1 to permit http:// and private/loopback targets (dev/self-host LAN).
ALLOW_PRIVATE_WEBHOOK_TARGETS=1

# Email transport — powers the `email` alert channel AND auth flows (password reset, org
# invitations, email verification). Transport is auto-selected: EMAIL_TRANSPORT (resend|smtp)
# if set, else Resend when RESEND_API_KEY is set, else SMTP when SMTP_CONNECTION_URL or
# SMTP_HOST is set, else disabled. When disabled, auth emails are LOGGED to stderr in
# development (click the link from the terminal) so flows stay testable without a mail server.
# `From` = EMAIL_FROM.
# EMAIL_TRANSPORT=resend
# EMAIL_FROM=memoturn <alerts@yourdomain.com>
# RESEND_API_KEY=re_...
#
# SMTP — either a single connection URL (smtp:// / smtps:// / ses://<region>) …
# SMTP_CONNECTION_URL=smtp://user:pass@smtp.yourprovider.com:587
# … or the discrete vars (the connection URL wins when both are set):
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
#
# Local dev: `bun run infra:up` starts Mailpit (SMTP :1025, web UI http://localhost:8025).
# Point auth/alert email at it to see rendered mail offline — no provider account needed:
# SMTP_CONNECTION_URL=smtp://localhost:1025

# Cloud/hosted only: disable NEW email/password signups (existing bootstrap logins still
# work). Leave unset for self-host so the first admin can register without an IdP/SMTP.
# AUTH_DISABLE_PASSWORD_SIGNUP=true

# Social sign-in (optional). A provider's button appears only when BOTH its id and secret are
# set. Callback URL to register with the provider: ${AUTH_BASE_URL}/auth/callback/<provider>.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Passkeys (WebAuthn). Defaults derive from the console origin (AUTH_TRUSTED_ORIGINS); set
# these only when the console is served from a custom domain. rpID = registrable domain (no
# scheme/port); PASSKEY_ORIGIN = full origin. They must match the site users register from.
# PASSKEY_RP_ID=memoturn.example.com
# PASSKEY_ORIGIN=https://memoturn.example.com

# SSO: a federated user is auto-joined to the organization bound to their provider. They land
# as "member" unless the IdP asserts one of these groups/roles (comma-separated, matched
# against the groups/roles/role claims) — then org "admin". Leave empty to make everyone member.
# SSO_ADMIN_GROUPS=memoturn-admins,platform-admins

# Platform superadmins (cloud ops): user IDs that always pass admin-plugin authorization
# (list/ban users, impersonate), regardless of the user.role column. Comma-separated.
# SUPERADMIN_USER_IDS=

# Test-only: disable the Better Auth rate limiter so suites that sign in repeatedly (e2e)
# aren't 429'd by the built-in sign-in sub-limit. NEVER set this in production.
# AUTH_RATE_LIMIT_DISABLED=true

# SDK / examples — base URL is the API service; keys match `bun run seed`'s dev key.
MEMOTURN_BASE_URL=http://localhost:3001
MEMOTURN_PUBLIC_KEY=pk-mt-dev
MEMOTURN_SECRET_KEY=sk-mt-dev
