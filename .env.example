# ─── memoturn environment ─────────────────────────────────────────────────────
# Copy to .env and adjust. The defaults match infra/docker-compose.dev.yml.

NODE_ENV=development

# Postgres (OLTP — relational metadata via Prisma)
# Host port is 5433 in docker-compose.dev.yml to avoid clashing with other local Postgres.
DATABASE_URL=postgresql://memoturn:memoturn@localhost:5433/memoturn?schema=public

# ClickHouse (OLAP — traces/observations/scores)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=memoturn
CLICKHOUSE_PASSWORD=memoturn
CLICKHOUSE_DB=memoturn

# Redis / Valkey (BullMQ queues + caches) — host port 6380 to avoid clashes.
REDIS_URL=redis://localhost:6380

# Blob storage (S3-compatible; MinIO locally)
BLOB_ENDPOINT=http://localhost:9000
BLOB_REGION=us-east-1
BLOB_BUCKET=memoturn
BLOB_ACCESS_KEY_ID=memoturn
BLOB_SECRET_ACCESS_KEY=memoturn123
BLOB_FORCE_PATH_STYLE=true

# Hono API service (public /v1 + OTel receiver)
API_PORT=3001
# Per-project API rate limit (requests/minute, Redis-backed; 0 = disabled)
RATE_LIMIT_PER_MINUTE=0

# Worker health + metrics endpoint (/health, /metrics)
WORKER_PORT=3002

# Console (Vite SPA) — proxies /api -> the API service in dev
CONSOLE_PORT=3000
MEMOTURN_API_URL=http://localhost:3001

# Better Auth (dashboard auth)
BETTER_AUTH_SECRET=dev-secret-please-change-in-prod-0123456789
AUTH_BASE_URL=http://localhost:3001
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# SDK / examples — base URL is the API service; keys match `bun run seed`'s dev key.
MEMOTURN_BASE_URL=http://localhost:3001
MEMOTURN_PUBLIC_KEY=pk-mt-dev
MEMOTURN_SECRET_KEY=sk-mt-dev
