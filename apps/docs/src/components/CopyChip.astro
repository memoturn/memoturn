---
type Props = { command: string };

const { command } = Astro.props;
---

<button type="button" class="m-copy-chip" data-command={command} aria-label={`Copy command: ${command}`}>
	<span class="m-copy-chip__cmd" aria-hidden="true">{command}</span>
	<svg
		class="m-copy-chip__icon m-copy-chip__icon--copy"
		aria-hidden="true"
		width="14"
		height="14"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
		<path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
	</svg>
	<svg
		class="m-copy-chip__icon m-copy-chip__icon--check"
		aria-hidden="true"
		width="14"
		height="14"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<path d="M20 6 9 17l-5-5"></path>
	</svg>
	<span class="m-copy-chip__status sr-only" aria-live="polite"></span>
</button>

<style>
	/* Mirrors the marketing home's CopyChip: mono command + copy affordance
	 * in a single hairline chip, sized to the shared button spec. Styled for
	 * the atoll-gradient band. */
	.m-copy-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.625rem;
		height: 2.5rem;
		padding: 0 0.875rem;
		border: 1px solid var(--on-gradient-border);
		border-radius: var(--radius-lg);
		background: var(--on-gradient-button-bg);
		color: var(--on-gradient-fg);
		font-family: var(--font-mono-stack);
		font-size: 13px;
		letter-spacing: 0.01em;
		cursor: pointer;
		transition: border-color 180ms var(--ease-swell, ease);
	}

	.m-copy-chip:hover {
		border-color: var(--on-gradient-fg);
	}

	.m-copy-chip:focus-visible {
		outline: 2px solid var(--on-gradient-fg);
		outline-offset: 3px;
	}

	.m-copy-chip__cmd {
		user-select: all;
	}

	.m-copy-chip__icon--copy {
		opacity: 0.7;
		transition: opacity 180ms var(--ease-swell, ease);
	}

	.m-copy-chip:hover .m-copy-chip__icon--copy {
		opacity: 1;
	}

	.m-copy-chip__icon--check {
		display: none;
	}

	.m-copy-chip.is-copied .m-copy-chip__icon--copy {
		display: none;
	}

	.m-copy-chip.is-copied .m-copy-chip__icon--check {
		display: inline;
	}

	@media (prefers-reduced-motion: reduce) {
		.m-copy-chip,
		.m-copy-chip__icon--copy {
			transition: none;
		}
	}
</style>

<script>
	for (const btn of document.querySelectorAll<HTMLButtonElement>(".m-copy-chip")) {
		let timer: ReturnType<typeof setTimeout> | undefined;
		btn.addEventListener("click", async () => {
			const command = btn.dataset.command ?? "";
			try {
				await navigator.clipboard.writeText(command);
			} catch {
				return; // clipboard unavailable — the command text stays selectable
			}
			btn.classList.add("is-copied");
			btn.setAttribute("aria-label", "Copied");
			const status = btn.querySelector(".m-copy-chip__status");
			if (status) status.textContent = "Command copied to clipboard";
			clearTimeout(timer);
			timer = setTimeout(() => {
				btn.classList.remove("is-copied");
				btn.setAttribute("aria-label", `Copy command: ${command}`);
				if (status) status.textContent = "";
			}, 2000);
		});
	}
</script>
