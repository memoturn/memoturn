{
  "name": "@memoturn/web",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3003",
    "build": "vite build",
    "preview": "bun run build && vite preview",
    "lint": "biome check .",
    "typecheck": "wrangler types && tsr generate && tsc --noEmit",
    "deploy": "bun run build && wrangler deploy",
    "deploy:staging": "CF_ENV=staging vite build --mode staging && wrangler deploy",
    "cf-typegen": "wrangler types",
    "clean": "rm -rf dist .turbo .wrangler .tanstack src/routeTree.gen.ts worker-configuration.d.ts"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.33.2",
    "@memoturn/ui": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.168.24",
    "@tanstack/react-start": "^1.167.47",
    "@tanstack/router-plugin": "^1.167.25",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@memoturn/tsconfig": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/router-cli": "^1.167.17",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wrangler": "^4.85.0"
  }
}
