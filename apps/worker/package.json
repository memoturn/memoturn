{
  "name": "@memoturn/worker",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch --env-file=../../.env src/index.ts",
    "dev:status": "bun ../../scripts/check-port.ts worker 3002 /health",
    "start": "bun src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@memoturn/contracts": "workspace:*",
    "@memoturn/core": "workspace:*",
    "@memoturn/db": "workspace:*",
    "@memoturn/server": "workspace:*",
    "@memoturn/telemetry": "workspace:*",
    "bullmq": "^5.79.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
